    "entropy_threshold": 0.85
  },
  "permissions": {
    "level": "NetworkRestricted",
    "network": true,
    "filesystem": false,
    "mcp_servers": [
      "whatsapp-bridge"
    ]
  },
  "soul_type": "KV_CACHE"
}
