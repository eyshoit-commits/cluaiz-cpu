{
  "id": "whatsapp-native",
  "name": "WhatsApp Sovereign Messenger",
  "version": "1.0.0",
  "author": "Cluaiz-OS Neural Foundry",
  "description": "Securely sends and receives WhatsApp messages via a local sovereign gateway.",
  "triggers": {
    "semantic": [
      "whatsapp",
      "send message",
      "message to",
      "ping on whatsapp"
