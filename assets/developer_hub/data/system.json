{
  "group": "System & Control",
  "endpoints": [
    {
      "method": "GET",
      "path": "/health",
      "desc": "Checks the core engine health, memory status, and continuous uptime.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/system/health.md",
      "params": [],
      "response": "{\n  \"status\": \"healthy\",\n  \"uptime_ms\": 145020\n}"
    },
    {
      "method": "GET",
      "path": "/info",
      "desc": "Retrieves deep architectural information, versioning, and the foundational pillars of the cluaiz system.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/system/info.md",
      "params": [],
      "response": "{\n  \"engine\": \"cluaiz Inference Engine\",\n  \"version\": \"0.1.0\"\n}"
    },
    {
      "method": "GET",
      "path": "/v1/system/ps",
      "desc": "Show active neural engines in memory and their current process IDs. Crucial for load balancers.",
      "docs_url": "https://raw.githubusercontent.com/cluaiz/cluaiz/main/README.md",
      "params": [],
      "response": "{\n  \"status\": \"success\",\n  \"active_processes\": [\n    {\n      \"pid\": \"29514\",\n      \"model_id\": \"bonsai:8b\",\n      \"vram_gb\": 4.2,\n      \"context_size\": 8192,\n      \"engine\": \"llama.cpp\"\n    }\n  ]\n}"
    },
    {
      "method": "GET",
      "path": "/v1/system/control",
      "desc": "Gets the overall hardware orchestrator system control states including brain connection state and hardware limits.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/system/control.md",
      "params": [],
      "response": "{\n  \"brain\": {\n    \"cluaizdb_connect_ffi\": \"on\"\n  },\n  \"silicon_truth\": {\n    \"memory\": {\"total_capacity_gb\": 32.0}\n  }\n}"
    },
    {
      "method": "GET",
      "path": "/v1/system/permission",
      "desc": "Gets the current active permission schema and firewall rules for the neural foundry.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/system/permission_get.md",
      "params": [],
      "response": "{\n  \"wasm_firewall\": \"strict\",\n  \"vectorize_user_input\": true,\n  \"stream_telemetry\": false\n}"
    },
    {
      "method": "POST",
      "path": "/v1/system/permission",
      "desc": "Updates a specific permission rule natively.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/system/permission_post.md",
      "params": [
        {
          "name": "key",
          "type": "string",
          "req": true,
          "desc": "The permission key to change (e.g. 'wasm_firewall').",
          "default": "wasm_firewall"
        },
        {
          "name": "value",
          "type": "string",
          "req": true,
          "desc": "The new value for the permission.",
          "default": "relaxed"
        }
      ],
      "response": "{\n  \"status\": \"success\"\n}"
    },
    {
      "method": "POST",
      "path": "/engine/skip_think",
      "desc": "Instructs the engine to skip the '<think>' reasoning block during the next generation.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/system/skip_think.md",
      "params": [
        {
          "name": "skip",
          "type": "boolean",
          "req": true,
          "desc": "Whether to skip thinking tags in output.",
          "default": true
        }
      ],
      "response": "{\n  \"status\": \"success\"\n}"
    },
    {
      "method": "POST",
      "path": "/v1/system/cmd",
      "desc": "Executes shell commands locally. STRICTLY bound to 127.0.0.1 (Localhost). Rejects any remote attempts to prevent RCE.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/system/cmd.md",
      "params": [
        {
          "name": "command",
          "type": "string",
          "req": true,
          "desc": "The raw shell command to execute.",
          "default": "echo Hello cluaiz"
        }
      ],
      "response": "{\n  \"status\": \"success\",\n  \"output\": \"Hello cluaiz\\n\"\n}"
    }
  ]
}