{
  "group": "Models & Vault",
  "endpoints": [
    {
      "method": "GET",
      "path": "/api/tags",
      "desc": "Ollama-compatible endpoint to list all available models.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/models/tags.md",
      "params": [],
      "response": "{\n  \"models\": [\n    {\n      \"name\": \"llama3:8b\",\n      \"model\": \"llama3:8b\",\n      \"modified_at\": \"2024-05-01T12:00:00Z\",\n      \"size\": 4200000000\n    }\n  ]\n}"
    },
    {
      "method": "POST",
      "path": "/api/pull",
      "desc": "Pulls an external compatible model from remote registries.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/models/pull.md",
      "params": [
        { "name": "name", "type": "string", "req": true, "desc": "Model tag or identifier.", "default": "qwen:0.5b" }
      ],
      "response": "{\n  \"status\": \"downloading\",\n  \"progress\": \"25%\"\n}"
    },
    {
      "method": "GET",
      "path": "/models/available",
      "desc": "Legacy. Lists available online models for download.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/models/available.md",
      "params": [],
      "response": "[\n  {\"id\": \"llama-3-8b-instruct\", \"type\": \"chat\"}\n]"
    },
    {
      "method": "GET",
      "path": "/v1/models/installed",
      "desc": "Lists locally installed models inside the cluaiz Vault.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/models/installed.md",
      "params": [],
      "response": "[\n  {\"id\": \"llama-3-8b-instruct\", \"status\": \"ready\", \"size_gb\": 4.5}\n]"
    },
    {
      "method": "GET",
      "path": "/hardware",
      "desc": "Legacy hardware status check.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/models/hardware.md",
      "params": [],
      "response": "{\n  \"vram_total\": 16.0,\n  \"vram_free\": 12.0\n}"
    },
    {
      "method": "POST",
      "path": "/models/download",
      "desc": "Downloads a .gguf format model from Hugging Face into the local secure vault.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/models/download.md",
      "params": [
        { "name": "repo_id", "type": "string", "req": true, "desc": "Hugging Face repo ID.", "default": "unsloth/llama-3-8b" },
        { "name": "filename", "type": "string", "req": true, "desc": "Specific file to download.", "default": "llama-3-8b.gguf" }
      ],
      "response": "{\n  \"status\": \"queued\"\n}"
    },
    {
      "method": "POST",
      "path": "/models/load",
      "desc": "Loads a downloaded model into VRAM/RAM for active inference.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/models/load.md",
      "params": [
        { "name": "model_id", "type": "string", "req": true, "desc": "The local ID of the model.", "default": "llama-3-8b" },
        { "name": "gpu_layers", "type": "integer", "req": false, "desc": "Number of layers to offload to GPU.", "default": -1 }
      ],
      "response": "{\n  \"status\": \"success\"\n}"
    },
    {
      "method": "POST",
      "path": "/v1/hardware/calibrate",
      "desc": "Recalibrates the Hardware Governor (checks RAM, VRAM, CPU topologies dynamically).",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/models/calibrate.md",
      "params": [],
      "response": "{\n  \"status\": \"success\",\n  \"message\": \"Hardware recalibrated.\"\n}"
    },
    {
      "method": "DELETE",
      "path": "/v1/models/{model_id}",
      "desc": "Deletes a model permanently from the local vault.",
      "docs_url": "https://cdn.jsdelivr.net/gh/cluaiz/cluaiz@main/docs/models/rm.md",
      "params": [],
      "response": "{\n  \"status\": \"success\",\n  \"message\": \"Model deleted.\"\n}"
    }
  ]
}
